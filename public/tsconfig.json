{
    "compilerOptions": {
        "moduleResolution": "node",
        "module": "commonjs",
        "target": "es2020",
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "sourceMap": false,
        "removeComments": false,
        "outDir": "../host/",
    },
    "include": [
        "**/*"
    ],
    "exclude": [
        "node_modules",
        "contextBridge.ts",
        "factories/**",
        "utils/invokeHelper.ts",
        "interfaces/**",
        "**/*.spec.ts"
    ]
}