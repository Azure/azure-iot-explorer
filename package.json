{
  "name": "azure-iot-explorer",
  "version": "0.15.17",
  "description": "This project welcomes contributions and suggestions. Most contributions require you to agree to a\r Contributor License Agreement (CLA) declaring that you have the right to, and actually do, grant us\r the rights to use your contribution. For details, visit https://cla.microsoft.com.",
  "main": "host/electron.js",
  "build": {
    "appId": "com.microsoft.azure.iot.pnp.ui",
    "productName": "Azure IoT Explorer Preview",
    "files": [
      "dist/**/*",
      "package.json",
      "host/**/*"
    ],
    "directories": {
      "buildResources": "icon"
    },
    "afterPack": "./scripts/flipFuses.js",
    "linux": {
      "category": "Utility",
      "executableName": "azure-iot-explorer",
      "target": [
        "deb"
      ]
    },
    "mac": {
      "type": "distribution",
      "icon": "icon/icon.icns"
    },
    "dmg": {
      "internetEnabled": true
    },
    "win": {
      "target": [
        "msi"
      ]
    },
    "msi": {
      "additionalLightArgs": [
        "-sval"
      ]
    },
    "publish": null
  },
  "scripts": {
    "build": "npm run localization && npm run webpack:compile && npm run preload:compile && npm run electron:compile && webpack --mode production --config webpack.electron.js",
    "pack:win": "electron-builder --dir",
    "dist:win": "electron-builder -w --prepackaged ./dist/win-unpacked",
    "clean": "IF EXIST .\\dist RMDIR /Q /S .\\dist",
    "clean:linux": "rm --recursive -f ./dist",
    "localization": "tsc --ignoreConfig --types node --module node16 --moduleResolution node16 ./scripts/composeLocalizationKeys.ts --skipLibCheck && node ./scripts/composeLocalizationKeys.js",
    "import-semantic-units": "tsc --ignoreConfig --types node --module node16 --moduleResolution node16 ./scripts/importSemanticUnitTypes.ts --skipLibCheck && node ./scripts/importSemanticUnitTypes.js",
    "docker": "docker pull electronuserland/electron-builder && docker run --rm -ti --mount source=$(pwd),target=/project,type=bind electronuserland/electron-builder:latest",
    "electron": "electron .",
    "electron:compile": "tsc --project ./public/tsconfig.json",
    "preload:compile": "webpack --mode production --config webpack.preload.js",
    "package:win": "npm run clean && npm ci --legacy-peer-deps & npm rebuild sass && npm run build && electron-builder -w",
    "package:linux": "npm run clean:linux && npm ci --legacy-peer-deps && npm rebuild sass && npm run build && electron-builder -l",
    "package:mac": "npm ci --legacy-peer-deps && npm rebuild sass && npm run build && electron-builder -m",
    "webpack:compile": "tsc --ignoreConfig --target es2025 --module node16 --moduleResolution node16 --skipLibCheck ./webpack.common.ts webpack.electron.ts webpack.dev.ts webpack.preload.ts",
    "start": "npm run start:dev",
    "start:dev": "concurrently \"npm run start:web:dev\" \"npm run start:electron:dev\"",
    "start:web:dev": "npm run localization && npm run webpack:compile && webpack-dev-server --config webpack.dev.js --mode development --hot --port 3000 --host 127.0.0.1",
    "start:electron:dev": "wait-on http://localhost:3000 && npm run electron:compile && npm run preload:compile && cross-env NODE_ENV=development electron .",
    "test": "npm run localization && jest --coverage",
    "test:debug": "node --inspect-brk ./node_modules/jest/bin/jest.js --runInBand -i --watch",
    "test:updateSnapshot": "jest --updateSnapshot",
    "test:watch": "jest --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Azure/azure-iot-explorer.git"
  },
  "author": "Microsoft <iotupx@microsoft.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Azure/azure-iot-explorer/issues"
  },
  "homepage": "https://github.com/Azure/azure-iot-explorer#readme",
  "overrides": {
    "ts-jest": {
      "typescript": "$typescript"
    },
    "react-monaco-editor": {
      "monaco-editor": "$monaco-editor"
    }
  },
  "dependencies": {
    "@azure/core-amqp": "^4.4.2",
    "@azure/event-hubs": "^6.0.4",
    "@azure/msal-node": "^5.1.5",
    "@fluentui/react-components": "^9.73.8",
    "@fluentui/react-datepicker-compat": "^0.6.31",
    "@fluentui/react-icons": "^2.0.325",
    "@fluentui/react-migration-v0-v9": "^9.6.28",
    "@fluentui/react-timepicker-compat": "^0.4.34",
    "@microsoft/applicationinsights-web": "^3.4.1",
    "@rjsf/core": "^6.5.1",
    "@rjsf/fluentui-rc": "^6.5.1",
    "@rjsf/utils": "^6.5.1",
    "@rjsf/validator-ajv8": "^6.5.1",
    "azure-iot-common": "^1.12.14",
    "azure-iothub": "^1.16.5",
    "date-fns": "^4.1.0",
    "electron-window-state": "^5.0.3",
    "escape-html": "^1.0.3",
    "he": "^1.2.0",
    "i18next": "^26.0.8",
    "immutable": "^5.1.5",
    "jsonschema": "^1.2.4",
    "monaco-editor": "^0.55.1",
    "node-fetch": "^2.6.7",
    "node-forge": "^1.3.3",
    "protobufjs": "^8.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.6",
    "react-monaco-editor": "^0.59.0",
    "react-movable": "^3.4.1",
    "react-router-dom": "^7.14.2",
    "react-toastify": "^11.0.0",
    "redux-saga": "^1.1.3",
    "semver": "^7.7.4",
    "ssrf-req-filter": "^1.1.1",
    "typescript-fsa": "^3.0.0-beta-2",
    "typescript-fsa-reducers": "^1.0.0",
    "uuid": "^14.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.1",
    "@redux-saga/testing-utils": "^1.1.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/escape-html": "^1.0.4",
    "@types/he": "^1.2.3",
    "@types/jest": "^30.0.0",
    "@types/jest-plugin-context": "^2.9.0",
    "@types/node": "^25.6.0",
    "@types/node-fetch": "^2.6.2",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/semver": "^7.7.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "concurrently": "^9.2.1",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-webpack-plugin": "^6.0.0",
    "html-webpack-plugin": "^5.5.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-plugin-context": "^2.9.0",
    "jest-trx-results-processor": "^3.0.2",
    "lodash": "^4.17.21",
    "mini-css-extract-plugin": "^2.6.0",
    "node-polyfill-webpack-plugin": "^4.1.0",
    "nodemon": "^3.1.0",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "source-map-loader": "^5.0.0",
    "ssri": "^13.0.1",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.2.8",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "wait-on": "^9.0.3",
    "webpack": "^5.97.1",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.0",
    "webpack-merge": "^6.0.1",
    "webpack-shell-plugin": "^0.5.0"
  },
  "jest": {
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*Container.{ts,tsx}",
      "!src/app/jsonSchemaFormFabricPlugin/widgets/*.tsx",
      "!src/app/jsonSchemaFormFabricPlugin/fields/*.tsx",
      "!src/app/shared/redux/store.ts",
      "!src/app/shared/redux/reducer.ts",
      "!src/app/shared/redux/store/configureStore.ts",
      "!src/app/shared/utils/exceptions/*.ts",
      "!src/index.tsx",
      "!src/localization/resources.ts"
    ],
    "testEnvironment": "jsdom",
    "coverageReporters": [
      "html",
      "cobertura"
    ],
    "setupFiles": [
      "jest-plugin-context/setup",
      "./jestSetup.ts"
    ],
    "setupFilesAfterEnv": [
      "@testing-library/jest-dom"
    ],
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": "./tsconfig-jest.json",
          "diagnostics": false
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!react-movable|@azure/event-hubs|@azure/core-amqp|@azure/core-auth|@azure/core-rest-pipeline|@azure/core-tracing|@azure/core-util|@azure/abort-controller|@azure/logger|@typespec/ts-http-runtime|@rjsf/utils|@rjsf/core|@rjsf/fluent-ui|@x0k/json-schema-merge|uuid)"
    ],
    "testRegex": "(\\.|/)(spec)\\.(tsx?)$",
    "moduleNameMapper": {
      "^.+\\.(scss)$": "<rootDir>/scss-stub.js",
      ".+\\appconfig.ENV.json": "<rootDir>/src/appConfig/appConfig.dev.json"
    },
    "moduleFileExtensions": [
      "js",
      "json",
      "jsx",
      "ts",
      "tsx"
    ],
    "snapshotSerializers": [],
    "testEnvironmentOptions": {
      "url": "http://localhost?trustedAuthority=https://localhost"
    },
    "reporters": [
      "default",
      [
        "jest-trx-results-processor",
        {
          "outputFile": "jest-test-results.trx"
        }
      ]
    ],
    "preset": "ts-jest/presets/js-with-ts",
    "testMatch": null
  }
}
